{
    "manifest_version": 3,
    "name": "URL to Markdown Link Copy",
    "version": "1.0",
    "description": "閲覧中のページのURLをMarkdown形式でコピーします。一部ドメインのカテゴリ名自動変換やAmazonのURL短縮に対応しています。",
    "permissions": [
        "activeTab",
        "clipboardWrite",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Copy Markdown Link",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}